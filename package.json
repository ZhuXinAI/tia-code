{
  "name": "tia-code",
  "version": "0.1.2",
  "description": "A local terminal coding agent with interactive and scriptable modes.",
  "author": "ZhuXinAI",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhuXinAI/tia-code.git"
  },
  "bugs": {
    "url": "https://github.com/ZhuXinAI/tia-code/issues"
  },
  "homepage": "https://github.com/ZhuXinAI/tia-code#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tia-code": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "screenshot.png"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "terminal"
  ],
  "scripts": {
    "dev": "node --import tsx/esm src/dev.ts",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx/esm --test test/*.test.ts",
    "prepack": "npm run build && npm run test"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^2.0.16",
    "@assistant-ui/react-ink": "latest",
    "@assistant-ui/react-ink-markdown": "latest",
    "@earendil-works/pi-coding-agent": "0.80.8",
    "ai": "^7.0.34",
    "assistant-cloud": "^0.1.35",
    "ink": "^7.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
